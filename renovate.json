{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>maki-it/renovate-config"
  ],
  "git-submodules": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "Update Frappe app versions pinned in apps.json",
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps.json$/"
      ],
      "matchStrings": [
        "\"url\":\\s*\"https://github\\.com/(?<depName>[^\"]+)\\.git\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "description": "Update frappe_version in GitHub Actions workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/build\\.ya?ml$/"
      ],
      "matchStrings": [
        "frappe_version:\\s*[\\s\\S]*?default:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "frappe/frappe",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
